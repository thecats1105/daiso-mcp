{
  "name": "daiso",
  "version": "1.0.4",
  "description": "Daiso MCP Server for mobile access via Cloudflare Workers",
  "main": "dist/index.js",
  "bin": {
    "daiso": "dist/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "openapi.json",
    "openapi.yaml"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "scripts": {
    "hooks:install": "git config core.hooksPath .githooks && chmod +x .githooks/pre-push",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "tsc && node scripts/generate-openapi.mjs",
    "build:openapi": "node scripts/generate-openapi.mjs",
    "update:workers-chart": "node scripts/update-workers-invocations-chart.mjs",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check && npm run build",
    "release:dry-run": "npm pack --dry-run",
    "publish:public": "npm publish --access public",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.mjs\" \"vitest.config.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.mjs\" \"vitest.config.ts\" --fix",
    "format": "prettier .github/**/*.md .github/**/*.yml README.md SECURITY.md AGENTS.md CONTRIBUTING.md package.json tsconfig.json .prettierrc.json .mcp.json eslint.config.mjs --write",
    "format:check": "prettier .github/**/*.md .github/**/*.yml README.md SECURITY.md AGENTS.md CONTRIBUTING.md package.json tsconfig.json .prettierrc.json .mcp.json eslint.config.mjs --check",
    "cf-typegen": "wrangler types",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm test"
  },
  "keywords": [
    "mcp",
    "daiso",
    "cloudflare-workers",
    "serverless"
  ],
  "author": "hmmhmmhm",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hmmhmmhm/daiso-mcp.git"
  },
  "homepage": "https://github.com/hmmhmmhm/daiso-mcp#readme",
  "bugs": {
    "url": "https://github.com/hmmhmmhm/daiso-mcp/issues"
  },
  "engines": {
    "node": ">=20 <21"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250110.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^4.0.18",
    "chart.js": "^4.5.1",
    "chartjs-node-canvas": "^5.0.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18",
    "wrangler": "^4.69.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "hono": "^4.12.5",
    "workers-mcp": "^0.0.13"
  }
}
